{
	"schemaVersion": 1,
	"id": "skyblock-item-list",
	"version": "${version}",
	"name": "SkyBlock Item List",
	"description": "",
	"authors": [
		"Alex33856",
		"j10a1n15"
	],
	"contact": {
		"sources": "https://github.com/OperationPotato/ItemList",
		"issues": "https://github.com/OperationPotato/ItemList/issues"
	},
	"license": "",
	"icon": "assets/skyblock-item-list/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "com.operationpotato.itemlist.SkyBlockItemList",
				"adapter": "kotlin"
			}
		],
		"skyblock-item-list": [
			{
				"value": "com.operationpotato.itemlist.api.impl.DefaultPlugin",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"skyblock-item-list.mixins.json"
	],
	"accessWidener": "skyblock-item-list.classtweaker",
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*",
		"skyblock-api": ">=${sbapi}"
	}
}
